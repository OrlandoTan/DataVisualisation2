{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "background": "transparent",
  "config": {
    "font": "Helvetica Neue, Helvetica, Arial, sans-serif",
    "axis": {
      "labelColor": "#9a9690",
      "labelFontSize": 11,
      "domainColor": "#e0dbd4",
      "tickColor": "#e0dbd4",
      "gridColor": "#e0dbd4",
      "gridOpacity": 0.6
    }
  },
  "layer": [

    {
      "description": "Area fill",
      "data": { "url": "../data/demand.csv" },
      "mark": {
        "type": "area",
        "color": "#c0392b",
        "opacity": 0.07,
        "interpolate": "monotone",
        "line": false
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": { "title": null, "labelAngle": 0 }
        },
        "y": {
          "field": "pct",
          "type": "quantitative",
          "scale": { "domain": [0, 1.3] },
          "axis": {
            "title": null,
            "labelExpr": "datum.value + '%'",
            "tickCount": 6
          }
        }
      }
    },

    {
      "description": "Main line",
      "data": { "url": "../data/demand.csv" },
      "mark": {
        "type": "line",
        "color": "#c0392b",
        "strokeWidth": 2,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": {
          "field": "pct",
          "type": "quantitative",
          "scale": { "domain": [0, 1.3] }
        }
      }
    },

    {
      "description": "Data points",
      "data": { "url": "../data/demand.csv" },
      "mark": {
        "type": "point",
        "color": "#c0392b",
        "filled": true,
        "size": 50,
        "stroke": "#f7f4ef",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": {
          "field": "pct",
          "type": "quantitative",
          "scale": { "domain": [0, 1.3] }
        }
      }
    },

    {
      "description": "Annotation rule at 2021",
      "data": { "values": [{ "year": "2021" }] },
      "mark": {
        "type": "rule",
        "color": "#c0392b",
        "opacity": 0.25,
        "strokeDash": [4, 4],
        "strokeWidth": 1
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" }
      }
    },

    {
      "description": "Annotation text at 2021",
      "data": { "values": [{ "year": "2021", "label": "Post-COVID recovery spike" }] },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": -90,
        "fontSize": 10,
        "fontStyle": "italic",
        "color": "#9a9690"
      },
      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "text": { "field": "label" }
      }
    }

  ]
}