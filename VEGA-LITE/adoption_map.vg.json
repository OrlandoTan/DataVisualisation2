{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 500,
  "background": "transparent",
  "config": {
    "font": "Helvetica Neue, Helvetica, Arial, sans-serif",
    "axis": {
      "labelColor": "#9a9690",
      "labelFontSize": 11,
      "domainColor": "#e0dbd4",
      "tickColor": "#e0dbd4",
      "gridColor": "#e0dbd4",
      "gridOpacity": 0.6
    }
  },
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "../data/STE_2016_AUST.json",
    "format": {
      "type": "topojson",
      "feature": "STE_2016_AUST"
    }
  },
  "transform": [
    {
      "lookup": "properties.STE_NAME16",
      "from": {
        "data": {
          "values": [
            {"state": "Victoria", "ai_adoption": 0.254},
            {"state": "New South Wales", "ai_adoption": 0.363},
            {"state": "Queensland", "ai_adoption": 0.191},
            {"state": "Western Australia", "ai_adoption": 0.094},
            {"state": "South Australia", "ai_adoption": 0.062},
            {"state": "Tasmania", "ai_adoption": 0.021},
            {"state": "Australian Capital Territory", "ai_adoption": 0.012},
            {"state": "Northern Territory", "ai_adoption": 0.003}
          ]
        },
        "key": "state",
        "fields": ["ai_adoption"]
      }
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "#ffffff",
    "strokeWidth": 1
  },
  "encoding": {
    "color": {
      "field": "ai_adoption",
      "type": "quantitative",
      "scale": {
        "scheme": "orangered"
      },
      "title": "AI Adoption Rate"
    },
    "tooltip": [
      {"field": "properties.STE_NAME16", "type": "nominal", "title": "State"},
      {"field": "ai_adoption", "type": "quantitative", "format": ".0%"}
    ]
  }
}