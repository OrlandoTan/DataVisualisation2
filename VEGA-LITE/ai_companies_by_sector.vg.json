{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 800,
  "height": 420,
  "background": "transparent",
  "padding": 0,

  "data": [
    {
      "name": "tree",
      "url": "../data/ai_companies_by_sector.csv",
      "transform": [
        {
          "type": "nest",
          "keys": ["sector"]
        },
        {
          "type": "treemap",
          "field": "companies",
          "sort": { "field": "value", "order": "descending" },
          "round": true,
          "method": "squarify",
          "ratio": 1.6,
          "size": [{ "signal": "width" }, { "signal": "height" }]
        }
      ]
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": { "data": "tree" },
      "encode": {
        "enter": {
          "x": { "field": "x0" },
          "x2": { "field": "x1" },
          "y": { "field": "y0" },
          "y2": { "field": "y1" },
          "fill": {
            "scale": "color",
            "field": "companies"
          },
          "stroke": { "value": "#f7f4ef" },
          "strokeWidth": { "value": 2 },
          "tooltip": {
            "signal": "{ 'Sector': datum.sector, 'Companies': datum.companies }"
          }
        }
      }
    },
    {
      "type": "text",
      "from": { "data": "tree" },
      "encode": {
        "enter": {
          "x": { "signal": "(datum.x0 + datum.x1) / 2" },
          "y": { "signal": "(datum.y0 + datum.y1) / 2" },
          "align": { "value": "center" },
          "baseline": { "value": "middle" },
          "fill": { "value": "#1a1814" },
          "fontSize": { "value": 11 },
          "font": { "value": "Helvetica Neue, Helvetica, Arial, sans-serif" },
          "fontWeight": { "value": 400 },
          "text": {
            "signal": "(datum.x1 - datum.x0) > 100 ? datum.sector : ''"
          },
          "limit": { "signal": "datum.x1 - datum.x0 - 12" }
        }
      }
    },
    {
      "type": "text",
      "from": { "data": "tree" },
      "encode": {
        "enter": {
          "x": { "signal": "(datum.x0 + datum.x1) / 2" },
          "y": { "signal": "(datum.y0 + datum.y1) / 2 + 16" },
          "align": { "value": "center" },
          "baseline": { "value": "middle" },
          "fill": { "value": "#4a4640" },
          "fontSize": { "value": 10 },
          "font": { "value": "Helvetica Neue, Helvetica, Arial, sans-serif" },
          "text": {
            "signal": "(datum.x1 - datum.x0) > 100 ? datum.companies + ' companies' : ''"
          }
        }
      }
    }
  ],

  "scales": [
    {
      "name": "color",
      "type": "linear",
      "domain": { "data": "tree", "field": "companies" },
      "range": ["#e8d5d2", "#c0392b"]
    }
  ]
}
