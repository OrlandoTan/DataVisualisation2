{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 340,
  "background": "transparent",
  "config": {
    "font": "Helvetica Neue, Helvetica, Arial, sans-serif",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#4a4640",
      "labelFontSize": 10,
      "titleColor": "#4a4640",
      "titleFontSize": 10,
      "titlePadding": 8,
      "domainColor": "#e0dbd4",
      "tickColor": "#4a4640",
      "tickSize": 4,
      "grid": false
    },
    "legend": {
      "labelColor": "#4a4640",
      "labelFontSize": 9,
      "titleColor": "#9a9690",
      "titleFontSize": 9,
      "titleFontWeight": "normal",
      "symbolStrokeWidth": 0
    }
  },
  "data": { "url": "../data/occupation_strip.csv" },
  "layer": [
    {
      "comment": "Thin guide line per row — connects dot to y-axis",
      "mark": { "type": "rule", "color": "#e0dbd4", "strokeWidth": 1 },
      "encoding": {
        "y": {
          "field": "occupation",
          "type": "nominal",
          "sort": { "field": "ai_demand", "order": "descending" }
        },
        "x":  { "datum": 0 },
        "x2": { "field": "ai_demand", "type": "quantitative" }
      }
    },
    {
      "comment": "National average rule",
      "mark": {
        "type": "rule",
        "color": "#4a4640",
        "strokeDash": [4, 3],
        "strokeWidth": 1,
        "opacity": 0.3
      },
      "encoding": { "x": { "datum": 0.9, "type": "quantitative" } }
    },
    {
      "comment": "National average label",
      "data": { "values": [{ "x": 0.9 }] },
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "dy": -6,
        "fontSize": 8.5,
        "fontStyle": "italic",
        "font": "Georgia, 'Times New Roman', serif",
        "color": "#4a4640",
        "opacity": 0.4
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "value": 0 },
        "text": { "value": "Nat. avg 0.9%" }
      }
    },
    {
      "comment": "Bubbles",
      "params": [
        { "name": "hover", "select": { "type": "point", "on": "mouseover", "clear": "mouseout" } }
      ],
      "mark": { "type": "point", "filled": true },
      "encoding": {
        "x": {
          "field": "ai_demand",
          "type": "quantitative",
          "title": "Share of job postings requiring AI skills",
          "scale": { "domain": [0, 9] },
          "axis": { "labelExpr": "datum.value + '%'", "values": [0, 1, 2, 3, 4, 5, 6, 7, 8], "orient": "bottom" }
        },
        "y": {
          "field": "occupation",
          "type": "nominal",
          "sort": { "field": "ai_demand", "order": "descending" },
          "axis": { "title": null, "labelLimit": 200, "ticks": false, "domain": false }
        },
        "size": {
          "field": "workers_thousands",
          "type": "quantitative",
          "scale": { "range": [40, 700] },
          "legend": {
            "title": "Workforce (thousands)",
            "values": [200, 500, 1000],
            "orient": "bottom-right",
            "symbolFillColor": "#9a9690"
          }
        },
        "color": {
          "field": "zone",
          "type": "nominal",
          "scale": {
            "domain": ["High demand", "Mid demand", "Low demand"],
            "range":  ["#de1e1c",    "#f0a090",    "#9a9690"   ]
          },
          "legend": null
        },
        "opacity": {
          "condition": { "param": "hover", "empty": false, "value": 1 },
          "value": 0.85
        },
        "tooltip": [
          { "field": "occupation",        "title": "Occupation" },
          { "field": "ai_demand",         "title": "AI demand (%)",       "format": ".1f" },
          { "field": "workers_thousands", "title": "Workers (thousands)", "format": "," },
          { "field": "zone",              "title": "Zone" }
        ]
      }
    }
  ]
}
